{
  "name": "my-pi-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "trap 'kill 0' EXIT; tsx watch src/server/main.ts & vite dev",
    "dev:server": "tsx watch src/server/main.ts",
    "dev:client": "vite dev",
    "build": "vite build && tsc --project tsconfig.server.json",
    "start": "node dist/server/main.js",
    "test": "npm run test:api && npm run test:e2e",
    "test:api": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@mariozechner/pi-web-ui": "^0.53.0",
    "express": "^5.1.0",
    "glob": "^11.0.0",
    "highlight.js": "^11.11.1",
    "marked": "^16.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "lit": "^3.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0"
  }
}
